<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>持股追蹤 — 智伸科・中美晶・日電貿・長興</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #0f1117;
  --bg2: #161b27;
  --bg3: #1e2535;
  --border: rgba(255,255,255,0.08);
  --border2: rgba(255,255,255,0.14);
  --text: #e8eaf0;
  --text2: #8892a4;
  --text3: #555f72;
  --green: #22d07a;
  --green-dim: rgba(34,208,122,0.12);
  --red: #f05c5c;
  --red-dim: rgba(240,92,92,0.12);
  --amber: #f0a840;
  --amber-dim: rgba(240,168,64,0.12);
  --blue: #4d9fff;
  --blue-dim: rgba(77,159,255,0.12);
  --purple: #a78bfa;
  --accent: #4d9fff;
  --mono: 'JetBrains Mono', monospace;
  --sans: 'Noto Sans TC', sans-serif;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body { background: var(--bg); color: var(--text); font-family: var(--sans); min-height: 100vh; font-size: 14px; line-height: 1.6; }

/* ── Layout ── */
.app { max-width: 1280px; margin: 0 auto; padding: 24px 20px 60px; }
header { margin-bottom: 32px; display: flex; align-items: flex-start; justify-content: space-between; flex-wrap: wrap; gap: 16px; }
.logo { display: flex; flex-direction: column; gap: 4px; }
.logo h1 { font-size: 20px; font-weight: 700; letter-spacing: .01em; color: var(--text); }
.logo p { font-size: 12px; color: var(--text3); font-family: var(--mono); }
.header-actions { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; }

/* ── Cards ── */
.card { background: var(--bg2); border: 1px solid var(--border); border-radius: 12px; padding: 20px; }
.card + .card { margin-top: 16px; }
.card-title { font-size: 11px; font-weight: 500; color: var(--text3); text-transform: uppercase; letter-spacing: .08em; margin-bottom: 16px; }

/* ── Summary metrics ── */
.metrics { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 20px; }
.metric { background: var(--bg3); border: 1px solid var(--border); border-radius: 10px; padding: 16px; }
.metric-label { font-size: 11px; color: var(--text3); margin-bottom: 6px; font-family: var(--mono); }
.metric-val { font-size: 22px; font-weight: 700; font-family: var(--mono); color: var(--text); }
.metric-val.up { color: var(--green); }
.metric-val.dn { color: var(--red); }

/* ── Input row ── */
.input-row { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; margin-bottom: 16px; padding: 16px; background: var(--bg3); border-radius: 10px; border: 1px solid var(--border); }
.input-group { display: flex; flex-direction: column; gap: 4px; }
.input-group label { font-size: 11px; color: var(--text3); font-family: var(--mono); }
.input-group input { background: var(--bg); border: 1px solid var(--border2); border-radius: 7px; color: var(--text); font-family: var(--mono); font-size: 14px; font-weight: 500; padding: 7px 10px; width: 100px; outline: none; transition: border-color .2s; }
.input-group input:focus { border-color: var(--accent); }

/* ── Buttons ── */
.btn { border-radius: 8px; padding: 8px 16px; font-size: 13px; font-family: var(--sans); font-weight: 500; cursor: pointer; transition: all .15s; border: none; white-space: nowrap; }
.btn-primary { background: var(--accent); color: #fff; }
.btn-primary:hover { opacity: .88; }
.btn-ghost { background: transparent; color: var(--text2); border: 1px solid var(--border2); }
.btn-ghost:hover { background: var(--bg3); color: var(--text); }
.btn-danger { background: var(--red-dim); color: var(--red); border: 1px solid rgba(240,92,92,.2); }
.btn-danger:hover { background: rgba(240,92,92,.2); }

/* ── Table ── */
.table-wrap { overflow-x: auto; }
table { width: 100%; border-collapse: collapse; font-size: 13px; }
th { text-align: left; padding: 8px 10px; font-size: 11px; font-weight: 500; color: var(--text3); border-bottom: 1px solid var(--border); text-transform: uppercase; letter-spacing: .05em; white-space: nowrap; }
td { padding: 12px 10px; border-bottom: 1px solid var(--border); vertical-align: middle; }
tr:last-child td { border-bottom: none; }
tfoot td { border-top: 1px solid var(--border2); font-weight: 500; color: var(--text); }
.stock-name { font-weight: 500; color: var(--text); }
.stock-code { font-family: var(--mono); font-size: 11px; color: var(--text3); }
.mono { font-family: var(--mono); }
.up { color: var(--green); }
.dn { color: var(--red); }
.dim { color: var(--text2); }

/* ── Progress bar ── */
.bar-wrap { background: var(--bg); border-radius: 3px; height: 4px; margin-top: 4px; overflow: hidden; min-width: 48px; }
.bar-fill { height: 100%; border-radius: 3px; transition: width .3s; }

/* ── Badges ── */
.badge { font-size: 11px; padding: 3px 8px; border-radius: 6px; font-weight: 500; white-space: nowrap; display: inline-block; }
.badge-green { background: var(--green-dim); color: var(--green); }
.badge-red { background: var(--red-dim); color: var(--red); }
.badge-amber { background: var(--amber-dim); color: var(--amber); }
.badge-blue { background: var(--blue-dim); color: var(--blue); }
.badge-dim { background: var(--bg3); color: var(--text3); }

/* ── Alerts ── */
.alert { padding: 10px 14px; border-radius: 8px; font-size: 12px; margin-top: 10px; border-left: 3px solid; line-height: 1.6; }
.alert-red { background: var(--red-dim); border-color: var(--red); color: #f8a0a0; }
.alert-amber { background: var(--amber-dim); border-color: var(--amber); color: #f5c878; }
.alert-green { background: var(--green-dim); border-color: var(--green); color: #6be0a8; }

/* ── Tabs ── */
.tabs { display: flex; gap: 2px; border-bottom: 1px solid var(--border); margin-bottom: 20px; }
.tab { background: transparent; border: none; padding: 10px 16px; font-size: 13px; cursor: pointer; color: var(--text3); font-family: var(--sans); border-bottom: 2px solid transparent; margin-bottom: -1px; transition: color .2s; }
.tab:hover { color: var(--text2); }
.tab.active { color: var(--text); border-bottom-color: var(--accent); font-weight: 500; }
.tab-content { display: none; }
.tab-content.active { display: block; }

/* ── Stop settings ── */
.stop-card { background: var(--bg3); border: 1px solid var(--border); border-radius: 10px; padding: 14px 16px; margin-bottom: 10px; }
.stop-card-head { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 10px; }
.stop-card-note { font-size: 11px; margin-top: 8px; padding-top: 8px; border-top: 1px solid var(--border); }
.stop-inp { background: var(--bg); border: 1px solid var(--border2); border-radius: 7px; color: var(--text); font-family: var(--mono); font-size: 13px; font-weight: 500; padding: 6px 9px; width: 80px; outline: none; transition: border-color .2s; }
.stop-inp:focus { border-color: var(--accent); }

/* ── History ── */
.hist-header { display: grid; grid-template-columns: 70px repeat(4,1fr) 90px; gap: 8px; padding: 6px 8px; font-size: 11px; color: var(--text3); font-weight: 500; text-transform: uppercase; letter-spacing: .05em; border-bottom: 1px solid var(--border); margin-bottom: 4px; }
.hist-row { display: grid; grid-template-columns: 70px repeat(4,1fr) 90px; gap: 8px; padding: 9px 8px; border-bottom: 1px solid var(--border); font-size: 13px; align-items: center; }
.hist-row:last-child { border-bottom: none; }
.hist-date { font-family: var(--mono); font-weight: 500; font-size: 12px; }
.hist-cell { font-family: var(--mono); }
.hist-total { font-family: var(--mono); font-weight: 700; }

/* ── Three layers ── */
.three-layers { display: grid; grid-template-columns: repeat(3,1fr); gap: 12px; margin-bottom: 20px; }
.layer-card { border-radius: 10px; padding: 14px; border: 1px solid; }
.layer-card.l1 { background: var(--red-dim); border-color: rgba(240,92,92,.25); }
.layer-card.l2 { background: var(--amber-dim); border-color: rgba(240,168,64,.25); }
.layer-card.l3 { background: rgba(167,139,250,.08); border-color: rgba(167,139,250,.25); }
.layer-title { font-size: 12px; font-weight: 700; margin-bottom: 6px; }
.layer-body { font-size: 12px; line-height: 1.65; }
.l1 .layer-title { color: var(--red); }
.l2 .layer-title { color: var(--amber); }
.l3 .layer-title { color: var(--purple); }
.l1 .layer-body { color: rgba(240,92,92,.8); }
.l2 .layer-body { color: rgba(240,168,64,.8); }
.l3 .layer-body { color: rgba(167,139,250,.8); }

/* ── Topic redline ── */
.redline-table td { font-size: 12px; color: var(--text2); }
.redline-table td:first-child { font-family: var(--mono); color: var(--text); font-weight: 500; }

/* ── Note ── */
.note { font-size: 12px; color: var(--text3); line-height: 1.7; padding: 10px 14px; background: var(--bg3); border-radius: 8px; border-left: 3px solid var(--accent); margin-top: 14px; }
.note strong { color: var(--text2); }

/* ── Responsive ── */
@media (max-width: 768px) {
  .metrics { grid-template-columns: repeat(2,1fr); }
  .three-layers { grid-template-columns: 1fr; }
  .input-row { gap: 8px; }
}
@media (max-width: 480px) {
  .metrics { grid-template-columns: 1fr 1fr; }
  .hist-header, .hist-row { grid-template-columns: 58px repeat(2,1fr) 72px; }
}

/* ── Scrollbar ── */
::-webkit-scrollbar { width: 6px; height: 6px; }
::-webkit-scrollbar-track { background: var(--bg); }
::-webkit-scrollbar-thumb { background: var(--bg3); border-radius: 3px; }
</style>
</head>
<body>
<div class="app">

<header>
  <div class="logo">
    <h1>📊 持股追蹤</h1>
    <p id="header-date">載入中...</p>
  </div>
  <div class="header-actions">
    <button class="btn btn-ghost" onclick="loadLast()">帶入上次收盤</button>
    <button class="btn btn-primary" onclick="saveToday()">💾 儲存今日</button>
  </div>
</header>

<!-- Summary metrics -->
<div class="metrics">
  <div class="metric"><div class="metric-label">總成本</div><div class="metric-val" id="m-total">$417,800</div></div>
  <div class="metric"><div class="metric-label">目前現值</div><div class="metric-val" id="m-cur">—</div></div>
  <div class="metric"><div class="metric-label">未實現損益</div><div class="metric-val" id="m-pnl">—</div></div>
  <div class="metric"><div class="metric-label">整體報酬率</div><div class="metric-val" id="m-pct">—</div></div>
</div>

<!-- Tabs -->
<div class="tabs">
  <button class="tab active" onclick="switchTab('today',this)">今日持倉</button>
  <button class="tab" onclick="switchTab('stop',this)">出場機制</button>
  <button class="tab" onclick="switchTab('hist',this)">歷史記錄</button>
  <button class="tab" onclick="switchTab('info',this)">持股資料</button>
</div>

<!-- 今日持倉 -->
<div id="tab-today" class="tab-content active">
  <div class="card">
    <div class="card-title">輸入今日收盤價</div>
    <div class="input-row">
      <div class="input-group"><label>智伸科 4551</label><input type="number" id="p4551" step="0.5" placeholder="收盤價" oninput="calc()"></div>
      <div class="input-group"><label>中美晶 5483</label><input type="number" id="p5483" step="0.5" placeholder="收盤價" oninput="calc()"></div>
      <div class="input-group"><label>日電貿 3090</label><input type="number" id="p3090" step="0.5" placeholder="收盤價" oninput="calc()"></div>
      <div class="input-group"><label>長興 1717</label><input type="number" id="p1717" step="0.5" placeholder="收盤價" oninput="calc()"></div>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>代號</th><th>建倉日</th><th>成本</th><th>今收</th>
            <th>損益(元)</th><th>報酬%</th>
            <th>ATR硬停損</th><th>移動停損</th><th>有效停損</th><th>距停損</th><th>狀態</th>
          </tr>
        </thead>
        <tbody id="hold-body"></tbody>
        <tfoot>
          <tr>
            <td colspan="2">合計</td>
            <td class="mono" id="f-cost">$417,800</td>
            <td></td>
            <td class="mono" id="f-pnl">—</td>
            <td class="mono" id="f-pct">—</td>
            <td colspan="5"></td>
          </tr>
        </tfoot>
      </table>
    </div>
    <div id="alert-area"></div>
    <div class="note">
      <strong>有效停損線</strong> = ATR硬停損 與 移動停損 取較高者。上次儲存：<span id="last-save-info">尚未儲存</span>
    </div>
  </div>
</div>

<!-- 出場機制 -->
<div id="tab-stop" class="tab-content">
  <div class="card">
    <div class="card-title">三層出場機制</div>
    <div class="three-layers">
      <div class="layer-card l1">
        <div class="layer-title">第一層 ATR硬停損</div>
        <div class="layer-body">本金保護底線，依各檔日均波動性估算。跌破後次日開盤全出，無商量餘地。</div>
      </div>
      <div class="layer-card l2">
        <div class="layer-title">第二層 移動停損</div>
        <div class="layer-body">股價每次創高站穩2-3天後手動上移，鎖住已獲利部分。一旦高於成本即確保不虧損出場。</div>
      </div>
      <div class="layer-card l3">
        <div class="layer-title">第三層 題材停利</div>
        <div class="layer-body">題材失效時主動出場，不等固定百分比。是真正讓你吃到波段的核心機制。</div>
      </div>
    </div>

    <div class="card-title" style="margin-top:4px">第二層：移動停損設定</div>
    <div id="stop-edit-list"></div>
    <div style="display:flex;gap:8px;margin-top:14px">
      <button class="btn btn-primary" onclick="saveMoveStops()">儲存移動停損</button>
    </div>
    <div class="note">
      移動停損上移時機：股價創近期新高並站穩2-3天後再上移，避免假突破後過早收緊。<br>
      <strong>長興(1717)</strong>目前在成本下方，移動停損暫設空值，股價回到成本以上再設定。
    </div>
  </div>

  <div class="card" style="margin-top:16px">
    <div class="card-title">第三層：題材紅線（出現任一訊號需認真考慮減碼）</div>
    <table class="redline-table">
      <colgroup><col style="width:80px"><col style="width:140px"><col></colgroup>
      <tbody>
        <tr><td>4551</td><td>精密零件・AI半導體</td><td>Q2/Q3法說下修 ／ AI半導體拉貨轉弱 ／ 外資連續3日大量賣超</td></tr>
        <tr><td>5483</td><td>低軌衛星・太空太陽能</td><td>衛星太陽能出貨延遲超過一季 ／ 外資大量轉賣超 ／ 月營收連續年減未改善</td></tr>
        <tr><td>3090</td><td>AI電源・HVDC 800V</td><td>電源架構升級進度延後 ／ 電源族群整體走弱3日以上 ／ 主要客戶轉單消息</td></tr>
        <tr><td>1717</td><td>液態封裝材料・台積電</td><td>Q3出貨低於法說預估 ／ 台積電訂單縮減 ／ 外資連賣且量大</td></tr>
      </tbody>
    </table>
  </div>
</div>

<!-- 歷史記錄 -->
<div id="tab-hist" class="tab-content">
  <div class="card">
    <div class="card-title" style="display:flex;justify-content:space-between;align-items:center">
      <span>每日損益歷史記錄</span>
      <button class="btn btn-danger" style="font-size:12px;padding:5px 10px" onclick="clearHist()">清除記錄</button>
    </div>
    <div class="hist-header">
      <div>日期</div><div>智伸科</div><div>中美晶</div><div>日電貿</div><div>長興</div><div>總損益</div>
    </div>
    <div id="hist-list"><div style="text-align:center;color:var(--text3);padding:24px;font-size:13px">尚無記錄，每日儲存後顯示於此</div></div>
  </div>
</div>

<!-- 持股資料 -->
<div id="tab-info" class="tab-content">
  <div class="card">
    <div class="card-title">持股基本資料</div>
    <div class="table-wrap">
      <table id="info-table">
        <thead>
          <tr><th>代號</th><th>名稱</th><th>建倉日</th><th>成本</th><th>ATR硬停損</th><th>三倍目標</th><th>核心題材</th></tr>
        </thead>
        <tbody id="info-body"></tbody>
      </table>
    </div>
  </div>
  <div class="card" style="margin-top:16px">
    <div class="card-title">ATR硬停損估算說明</div>
    <table>
      <colgroup><col style="width:80px"><col style="width:80px"><col style="width:80px"><col style="width:120px"><col style="width:90px"><col></colgroup>
      <thead><tr><th>代號</th><th>成本</th><th>估計日ATR</th><th>ATR硬停損</th><th>等效虧損</th><th>說明</th></tr></thead>
      <tbody>
        <tr><td class="mono">4551</td><td class="mono">127</td><td class="mono">~4.5元</td><td class="mono" style="color:var(--red)">118元</td><td class="mono">-7.1%</td><td style="font-size:12px;color:var(--text2)">比-20%保守，不易被日常震盪洗掉</td></tr>
        <tr><td class="mono">5483</td><td class="mono">106.5</td><td class="mono">~5.5元</td><td class="mono" style="color:var(--red)">95.5元</td><td class="mono">-10.3%</td><td style="font-size:12px;color:var(--text2)">大波動股，2倍ATR緩衝避免假跌破</td></tr>
        <tr><td class="mono">3090</td><td class="mono">105</td><td class="mono">~3.5元</td><td class="mono" style="color:var(--red)">98元</td><td class="mono">-6.7%</td><td style="font-size:12px;color:var(--text2)">100元整數為強支撐，硬停損設在之下</td></tr>
        <tr><td class="mono">1717</td><td class="mono">78.3</td><td class="mono">~3.5元</td><td class="mono" style="color:var(--red)">73元</td><td class="mono">-6.8%</td><td style="font-size:12px;color:var(--text2)">建倉未久，ATR值需持續觀察更新</td></tr>
      </tbody>
    </table>
    <div class="note">ATR值隨市場波動變化，建議每2週重新評估。可至券商軟體或TradingView查詢各股14日ATR值，再回填更新。</div>
  </div>
</div>

</div><!-- end .app -->

<script>
const STOCKS = [
  { code:'4551', name:'智伸科', entry:'2026/3/20',  cost:127,   atrStop:118,  topic:'精密零件・AI半導體・手術機器人' },
  { code:'5483', name:'中美晶', entry:'2026/4/7',   cost:106.5, atrStop:95.5, topic:'低軌衛星・太空太陽能・矽晶圓' },
  { code:'3090', name:'日電貿', entry:'2026/4/15',  cost:105,   atrStop:98,   topic:'AI電源・HVDC 800V・BBU' },
  { code:'1717', name:'長興',   entry:'2026/4/16',  cost:78.3,  atrStop:73,   topic:'液態封裝材料・台積電供應鏈・PCB乾膜光阻' },
];
const DEFAULT_MS = { '4551':135, '5483':120, '3090':103, '1717':null };
const TOTAL = 417800;
const LS = { hist:'pt_hist', last:'pt_last', ms:'pt_ms' };

const fmt = n => Math.round(n).toLocaleString();
const fmtP = p => p === null ? '—' : (p >= 0 ? '+' : '') + p.toFixed(2) + '%';
const pcls = p => p === null ? '' : p >= 0 ? 'up' : 'dn';
const gp = c => { const e = document.getElementById('p'+c); return e && e.value.trim() ? parseFloat(e.value) : null; };

function getMoveStops() {
  try { return JSON.parse(localStorage.getItem(LS.ms)) || DEFAULT_MS; } catch { return { ...DEFAULT_MS }; }
}

function daysSince(entry) {
  const [y,m,d] = entry.split('/').map(Number);
  return Math.max(0, Math.floor((new Date() - new Date(y,m-1,d)) / 86400000));
}

function calc() {
  const tb = document.getElementById('hold-body');
  tb.innerHTML = '';
  let tcur = 0, tpnl = 0, hc = false;
  const alerts = [];
  const ms = getMoveStops();

  STOCKS.forEach(s => {
    const costTotal = s.cost * 1000;
    const days = daysSince(s.entry);
    const cp = gp(s.code);
    const cv = cp ? cp * 1000 : null;
    const pnl = cv ? cv - costTotal : null;
    const pct = pnl !== null ? pnl / costTotal * 100 : null;
    if (cv) { tcur += cv; tpnl += pnl; hc = true; }

    const moveSL = ms[s.code] || null;
    const effSL = moveSL ? Math.max(s.atrStop, moveSL) : s.atrStop;
    const distToSL = cp ? (cp - effSL) / cp * 100 : null;
    const bw = pct !== null ? Math.min(Math.abs(pct) / 200 * 100, 100) : 0;
    const bc = pct !== null && pct < 0 ? 'var(--red)' : 'var(--green)';

    let badge = '<span class="badge badge-dim">待輸入</span>';
    if (pct !== null && cp !== null) {
      if (cp <= effSL) {
        badge = '<span class="badge badge-red">觸停損</span>';
        alerts.push({ name: s.name, type: 'sl', cp, sl: effSL });
      } else if (distToSL !== null && distToSL < 5) {
        badge = '<span class="badge badge-amber">接近停損</span>';
        alerts.push({ name: s.name, type: 'warn', cp, sl: effSL, dist: distToSL });
      } else if (pct > 0) {
        badge = '<span class="badge badge-green">獲利中</span>';
      } else {
        badge = '<span class="badge badge-amber">小幅虧損</span>';
      }
    }

    const moveSLHtml = moveSL
      ? `<span class="mono" style="color:var(--amber);font-weight:500">${moveSL}</span>`
      : `<span style="color:var(--text3);font-size:11px">未設定</span>`;
    const distHtml = distToSL !== null
      ? `<span class="mono ${distToSL < 5 ? 'dn' : distToSL < 10 ? '' : ''}" style="${distToSL<5?'color:var(--red)':distToSL<10?'color:var(--amber)':''}">${distToSL.toFixed(1)}%</span>`
      : '—';

    const tr = document.createElement('tr');
    tr.innerHTML = `
      <td><div class="stock-name">${s.name}</div><div class="stock-code">${s.code}</div></td>
      <td style="font-size:11px;color:var(--text3)">${s.entry}<br>${days}天</td>
      <td class="mono">${s.cost}<br><span style="font-size:10px;color:var(--text3)">$${fmt(costTotal)}</span></td>
      <td class="mono">${cp ? `<strong>${cp}</strong>` : '<span style="color:var(--text3)">—</span>'}</td>
      <td>
        <span class="mono ${pcls(pct)}">${pnl !== null ? (pnl >= 0 ? '+' : '') + fmt(pnl) : '—'}</span>
        ${pnl !== null ? `<div class="bar-wrap"><div class="bar-fill" style="width:${bw}%;background:${bc}"></div></div>` : ''}
      </td>
      <td class="mono ${pcls(pct)}">${fmtP(pct)}</td>
      <td class="mono" style="color:var(--red)">${s.atrStop}<br><span style="font-size:10px;color:var(--text3)">波動底線</span></td>
      <td>${moveSLHtml}<br><span style="font-size:10px;color:var(--text3)">可調整</span></td>
      <td class="mono" style="color:var(--red);font-weight:500">${effSL}<br><span style="font-size:10px;color:var(--text3)">實際保護</span></td>
      <td>${distHtml}</td>
      <td>${badge}</td>
    `;
    tb.appendChild(tr);
  });

  const D = id => document.getElementById(id);
  if (hc) {
    const pct = tpnl / TOTAL * 100;
    D('m-cur').textContent = '$' + fmt(tcur);
    D('m-cur').className = 'metric-val ' + (tpnl >= 0 ? 'up' : 'dn');
    D('m-pnl').textContent = (tpnl >= 0 ? '+' : '') + fmt(tpnl);
    D('m-pnl').className = 'metric-val ' + (tpnl >= 0 ? 'up' : 'dn');
    D('m-pct').textContent = fmtP(pct);
    D('m-pct').className = 'metric-val ' + (pct >= 0 ? 'up' : 'dn');
    D('f-pnl').textContent = (tpnl >= 0 ? '+' : '') + fmt(tpnl);
    D('f-pnl').className = 'mono ' + pcls(pct);
    D('f-pct').textContent = fmtP(pct);
    D('f-pct').className = 'mono ' + pcls(pct);
  } else {
    ['m-cur','m-pnl','m-pct'].forEach(id => { D(id).textContent = '—'; D(id).className = 'metric-val'; });
    ['f-pnl','f-pct'].forEach(id => { D(id).textContent = '—'; D(id).className = 'mono'; });
  }
  D('f-cost').textContent = '$' + fmt(TOTAL);

  const ab = D('alert-area');
  ab.innerHTML = '';
  alerts.forEach(a => {
    const cls = a.type === 'sl' ? 'alert-red' : 'alert-amber';
    const msg = a.type === 'sl'
      ? `⚠ ${a.name} 已觸及停損線 ${a.sl}元（現價 ${a.cp}元）→ 明日開盤全出`
      : `⚡ ${a.name} 距停損線僅剩 ${a.dist.toFixed(1)}%（現價 ${a.cp}，停損 ${a.sl}），請密切關注`;
    const el = document.createElement('div');
    el.className = 'alert ' + cls;
    el.textContent = msg;
    ab.appendChild(el);
  });
}

function buildStopEdit() {
  const c = document.getElementById('stop-edit-list');
  if (!c) return;
  c.innerHTML = '';
  const ms = getMoveStops();
  STOCKS.forEach(s => {
    const curMS = ms[s.code];
    const effSL = curMS ? Math.max(s.atrStop, curMS) : s.atrStop;
    const isAboveCost = curMS && curMS > s.cost;
    const noteColor = s.code === '1717' ? 'var(--amber)' : isAboveCost ? 'var(--green)' : 'var(--amber)';
    const noteText = s.code === '1717'
      ? '目前在成本下方，移動停損暫設空值，股價回升至成本以上後再設定'
      : isAboveCost
        ? `✓ 移動停損 ${curMS}元 高於成本 ${s.cost}元，確保不虧損出場`
        : `移動停損 ${curMS||'未設定'} 低於成本 ${s.cost}元，建議上移至成本以上`;

    const div = document.createElement('div');
    div.className = 'stop-card';
    div.innerHTML = `
      <div class="stop-card-head">
        <div>
          <div style="font-weight:500;font-size:13px">${s.name}（${s.code}）</div>
          <div style="font-size:11px;color:var(--text3);font-family:var(--mono);margin-top:2px">
            成本 ${s.cost} ／ ATR硬停損 ${s.atrStop} ／ 有效保護線 <strong style="color:var(--red)">${effSL}</strong>
          </div>
        </div>
        <div style="display:flex;align-items:center;gap:8px">
          <span style="font-size:11px;color:var(--text3)">移動停損：</span>
          <input class="stop-inp" id="ms-${s.code}" type="number" step="0.5" value="${curMS||''}" placeholder="設定價">
          <span style="font-size:11px;color:var(--text3)">元</span>
        </div>
      </div>
      <div class="stop-card-note" style="color:${noteColor}">${noteText}</div>
    `;
    c.appendChild(div);
  });
}

function saveMoveStops() {
  const ms = {};
  STOCKS.forEach(s => {
    const e = document.getElementById('ms-' + s.code);
    ms[s.code] = e && e.value.trim() ? parseFloat(e.value) : null;
  });
  localStorage.setItem(LS.ms, JSON.stringify(ms));
  calc();
  buildStopEdit();
  showToast('移動停損已儲存');
}

function saveToday() {
  const now = new Date();
  const dateStr = `${now.getMonth()+1}/${now.getDate()}`;
  const row = { date: dateStr, prices: {} };
  let valid = true;
  STOCKS.forEach(s => { const p = gp(s.code); if (!p) valid = false; row.prices[s.code] = p; });
  if (!valid) { alert('請先輸入全部四檔收盤價再儲存'); return; }
  try {
    const arr = JSON.parse(localStorage.getItem(LS.hist) || '[]');
    const idx = arr.findIndex(r => r.date === dateStr);
    if (idx >= 0) arr[idx] = row; else arr.unshift(row);
    if (arr.length > 90) arr.pop();
    localStorage.setItem(LS.hist, JSON.stringify(arr));
    localStorage.setItem(LS.last, JSON.stringify(row.prices));
  } catch(e) {}
  renderHist();
  document.getElementById('last-save-info').textContent = dateStr + ' ✓';
  showToast('今日收盤已儲存');
}

function loadLast() {
  try {
    const last = JSON.parse(localStorage.getItem(LS.last) || 'null');
    if (!last) { alert('尚無上次記錄'); return; }
    STOCKS.forEach(s => { if (last[s.code]) document.getElementById('p'+s.code).value = last[s.code]; });
    calc();
  } catch(e) {}
}

function renderHist() {
  try {
    const arr = JSON.parse(localStorage.getItem(LS.hist) || '[]');
    const c = document.getElementById('hist-list');
    c.innerHTML = '';
    if (!arr.length) {
      c.innerHTML = '<div style="text-align:center;color:var(--text3);padding:24px;font-size:13px">尚無記錄，每日儲存後顯示於此</div>';
      return;
    }
    arr.forEach(r => {
      let total = 0;
      STOCKS.forEach(s => { const p = r.prices[s.code]; if (p) total += (p - s.cost) * 1000; });
      const row = document.createElement('div');
      row.className = 'hist-row';
      row.innerHTML = `<div class="hist-date">${r.date}</div>` +
        STOCKS.map(s => {
          const p = r.prices[s.code];
          if (!p) return '<div class="hist-cell" style="color:var(--text3)">—</div>';
          const pct = (p - s.cost) / s.cost * 100;
          return `<div class="hist-cell"><strong>${p}</strong> <span class="${pcls(pct)}" style="font-size:11px">${fmtP(pct)}</span></div>`;
        }).join('') +
        `<div class="hist-total ${pcls(total)}">${total >= 0 ? '+' : ''}${fmt(total)}</div>`;
      c.appendChild(row);
    });
    if (arr[0]) document.getElementById('last-save-info').textContent = arr[0].date + ' ✓';
  } catch(e) {}
}

function clearHist() {
  if (!confirm('確定清除所有歷史記錄？')) return;
  localStorage.removeItem(LS.hist);
  localStorage.removeItem(LS.last);
  renderHist();
}

function buildInfo() {
  const tb = document.getElementById('info-body');
  STOCKS.forEach(s => {
    const tr = document.createElement('tr');
    tr.innerHTML = `
      <td class="mono" style="font-weight:500">${s.code}</td>
      <td>${s.name}</td>
      <td class="mono" style="font-size:12px;color:var(--text2)">${s.entry}</td>
      <td class="mono">${s.cost}元</td>
      <td class="mono" style="color:var(--red)">${s.atrStop}元</td>
      <td class="mono" style="color:var(--blue)">${(s.cost * 3).toFixed(1)}元</td>
      <td style="font-size:12px;color:var(--text2)">${s.topic}</td>
    `;
    tb.appendChild(tr);
  });
}

function switchTab(name, el) {
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('tab-' + name).classList.add('active');
  if (name === 'stop') buildStopEdit();
}

function showToast(msg) {
  let t = document.getElementById('toast');
  if (!t) {
    t = document.createElement('div');
    t.id = 'toast';
    t.style.cssText = 'position:fixed;bottom:24px;right:24px;background:#22d07a;color:#0a1a10;padding:10px 18px;border-radius:8px;font-size:13px;font-weight:500;z-index:9999;transition:opacity .3s';
    document.body.appendChild(t);
  }
  t.textContent = msg;
  t.style.opacity = '1';
  clearTimeout(t._timer);
  t._timer = setTimeout(() => t.style.opacity = '0', 2000);
}

// Init
const now = new Date();
const DAYS = ['日','一','二','三','四','五','六'];
document.getElementById('header-date').textContent =
  `${now.getFullYear()}/${now.getMonth()+1}/${now.getDate()}（星期${DAYS[now.getDay()]}）— 最後更新：${now.toLocaleTimeString('zh-TW',{hour:'2-digit',minute:'2-digit'})}`;

if (!localStorage.getItem(LS.ms)) {
  localStorage.setItem(LS.ms, JSON.stringify(DEFAULT_MS));
}

buildInfo();
renderHist();
const lastPrices = JSON.parse(localStorage.getItem(LS.last) || 'null');
if (lastPrices) STOCKS.forEach(s => { if (lastPrices[s.code]) document.getElementById('p'+s.code).value = lastPrices[s.code]; });
calc();
</script>
</body>
</html>
